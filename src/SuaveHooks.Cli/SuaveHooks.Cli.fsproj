<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace>SuaveHooks.Cli</RootNamespace>
    <AssemblyName>suavehooks</AssemblyName>
    <PackAsTool>true</PackAsTool>
    <ToolCommandName>suavehooks</ToolCommandName>
    <PackageId>SuaveHooks.Cli</PackageId>
    <Version>0.1.0</Version>
  </PropertyGroup>
  <ItemGroup>
    <Compile Include="Program.fs" />
  </ItemGroup>
</Project>
